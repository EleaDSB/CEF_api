<%- include('partials/header', { title: 'Accueil', user: null }) %>

  <section class="hero">
    <h2>Bienvenue sur l'application de gestion du port</h2>
    <p>Cette application privée permet à la capitainerie de gérer les catways et les réservations du port de plaisance Russell.</p>
    <a href="/docs" class="btn">Voir la documentation de l'API</a>
  </section>

  <section class="card">
    <h2>Connexion</h2>
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="votre@email.fr">
      </div>
      <div class="form-group">
        <label for="password">Mot de passe</label>
        <input type="password" id="password" name="password" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn">Se connecter</button>
    </form>
  </section>

<%- include('partials/footer') %>
