<%- include('partials/header', { title: 'Réservation', user }) %>

  <h2>Détails de la réservation</h2>
  <a href="/reservations" class="btn">← Retour</a>

  <section class="card">
    <p><strong>ID :</strong> <%= reservation._id %></p>
    <p><strong>Catway n° :</strong> <%= reservation.catwayNumber %></p>
    <p><strong>Client :</strong> <%= reservation.clientName %></p>
    <p><strong>Bateau :</strong> <%= reservation.boatName %></p>
    <p><strong>Arrivée :</strong> <%= new Date(reservation.checkIn).toLocaleDateString('fr-FR') %></p>
    <p><strong>Départ :</strong> <%= new Date(reservation.checkOut).toLocaleDateString('fr-FR') %></p>
  </section>

<%- include('partials/footer') %>
